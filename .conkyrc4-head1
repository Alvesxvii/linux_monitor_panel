# Crypto quotes card for the second monitor.
gap_x 1058
gap_y 580
update_interval 10
minimum_size 220 0
maximum_width 360
use_xft yes
xftfont caviar dreams:size=10
xftalpha 0.8
uppercase no
background yes
cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius
no_buffers yes
text_buffer_size 256
default_color FFFFFF
color1 8BB158
color2 7D7B7D
color3 7D7B7D
color4 FFFFF
color5 353535
own_window yes
own_window_type desktop
own_window_argb_visual yes
own_window_argb_value 90
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
total_run_times 0
draw_shades no
draw_outline no
draw_borders no
stippled_borders 0
border_margin 5
border_width 3
default_color 05FBE8
own_window_colour black
xinerama_head 1
alignment top_left
override_utf8_locale yes
use_spacer none
