# Script written by Warith Al Maawali  
# (c) 2019 Founder of Eagle Eye Digital Solutions
# http://www.digi77.com
# http://www.om77.net
# script starts here:

# Specific
gap_x 220
gap_y 30
update_interval 10
minimum_size 220 0
maximum_width 360


# General wide
use_xft yes
xftfont caviar dreams:size=10
xftalpha 0.8
uppercase no
background yes
cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius
no_buffers yes
text_buffer_size 256
default_color FFFFFF
color1 8BB158
color2 7D7B7D
color3 7D7B7D
color4 FFFFF 
color5 353535 

own_window yes
own_window_type desktop
own_window_argb_visual yes
own_window_argb_value 90 #value glass 0-250 full
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
total_run_times 0
 
# Minimum size of text area

draw_shades no
draw_outline no
draw_borders no
#draw_graph_borders yes
stippled_borders 0
border_margin 5
border_width 3

#Default colors and also border colors
default_color 05FBE8
#default_shade_color black
#default_outline_color grey
own_window_colour black
xinerama_head 0

#Text alignment, other possible values are commented
#alignment top_left
alignment top_right
#alignment bottom_left
#alignment bottom_right

 
override_utf8_locale yes
use_spacer none
 
 


TEXT
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}PRIVACIDADE E SEGURANÇA ${color5}${stippled_hr}${font}${voffset -0}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Internet:${alignr}${color1}${exec cat /home/alves/.kbase/netCurrentStatus|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Interface de rede:${alignr}${color1}${exec cat /home/alves/.kbase/intfused |xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Gateway: ${alignr}${color1}${if_gw}${gw_ip}${else}-${endif}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}MAC:${color1}${alignr}${exec cat /sys/class/net/$(find /sys/class/net ! -type d | xargs --max-args=1 realpath  | awk -F\/ '/pci/{print $NF}'|head -n1)/address}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Origem IP:${color1}${alignr}${exec cat /home/alves/.kbase/iptypeletter |xargs}
${color5}${stippled_hr}${font}${voffset -0}
${if_running openvpn}
#${if_running openvpn}${image /home/alves/.kbase/.conky/images/vpnon.png -p 50,70 -s 16x16}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}VPN: ${color1}${exec cat /home/alves/.kbase/vpntype |xargs}${color3}${alignr}Tempo: ${color1}${exec ps -eo pid,command,etime|grep 'openvpn --daemon --config'|awk  '{print $6}'|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}IP da VPN: ${color1}${exec cat /home/alves/.kbase/.eeds-ipinfo|cut -d : -f 1|tr -d " \t\n\r"}${alignr}${color1}${exec cat /home/alves/.kbase/.eeds-ipinfo|cut -d : -f 3|xargs}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Country: ${color1}${alignr}${exec geoiplookup `cat /home/alves/.kbase/.eeds-ipinfo|cut -d : -f 1`|cut -d : -f 2|cut -d , -f 2|xargs }
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Porta: ${color1}${exec cat /home/alves/.kbase/vpnattributes|grep port|cut -d = -f 2|tr -d " \t\n\r"}${alignr}${color3}Protocolo: ${color1}${alignr}${exec cat /home/alves/.kbase/vpnattributes|grep protocolu|cut -d = -f 2|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Status:${color1}${alignr}${exec cat /home/alves/.kbase/.eeds-ipinfo|cut -d : -f 2|cut -d [ -f 2|cut -d ] -f 1|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Ping:${color1}${alignr}${exec fping -B 1.0 -t 1000 -i 1 -r 0 -e -c 1 -q 9.9.9.9 2>&1 | awk -F'/' '{print $8}'} ms
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Largura de banda:${color1}${alignr}${exec cat /home/alves/.kbase/tvpnbandwidth|tr -d " \t\n\r"} GB
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Secure: ${color1}${alignr}Yes
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Perfil: ${color1}${alignr}${exec cat /home/alves/.kbase/vpnattributes|grep theProfile|cut -d = -f 2|xargs|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}IP do ISP: ${color1}${exec cat /home/alves/.kbase/.eeds-oipinfo|cut -d : -f 1|tr -d " \t\n\r"}${alignr}${color1}${exec cat /home/alves/.kbase/.eeds-ocipinfo|cut -d : -f 1|tr -d " \t\n\r"}
$else
#${image /home/alves/.conky/images/vpnoff.png -p 40,115 -s 40x40}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}VPN:${alignr}${color1}${alignr}-
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}IP do ISP: ${color1}${exec cat /home/alves/.kbase/.eeds-oipinfo|cut -d : -f 1|tr -d " \t\n\r"}${alignr}${color1}${exec cat /home/alves/.kbase/.eeds-ocipinfo|cut -d : -f 1|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Status: ${color1}${alignr}${exec cat /home/alves/.kbase/.eeds-ipinfo|cut -d : -f 2|cut -d [ -f 2|cut -d ] -f 1|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Ping:${color1}${alignr}${exec fping -B 1.0 -t 1000 -i 1 -r 0 -e -c 1 -q 8.8.8.8 2>&1 | awk -F'/' '{print $8}'} ms
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color red}${blink Caution: VPN is off....}
$endif
${color5}${stippled_hr}${font}${voffset -0}
#${if_running tor}${image /home/alves/.kbase/.conky/images/tor.png -p 65,70 -s 64x64}
${if_running tor}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Tor${color1}${alignr}${color3}Age: ${color1}${exec ps -eo pid,command,etime|grep 'tor'|grep 'bin'|cut -d r -f 4|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}${color1}${exec cat /home/alves/.kbase/.eeds-tipinfo|cut -d : -f 1|xargs}${alignr}${color1}${exec cat /home/alves/.kbase/.eeds-tipinfo|cut -d : -f 2|xargs }
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Tor with VPN only: ${color1}${exec cat /home/alves/.kbase/toronvpn|cut -d : -f 2|xargs }${alignr}${color3}Torified OS: ${color1}${alignr}${exec cat /home/alves/.kbase/torifysystemstatus|cut -d : -f 2|xargs }
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Excluded eyes: ${alignr}${color1}${exec cat /home/alves/.kbase/torblock14|cut -d : -f 2|xargs }
$else
#${image /home/alves/.conky/images/toroff.png -p 40,235 -s 40x40}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Tor${color1}${alignr}-
#${if_running openvpn}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color red}Tor Off
#$else
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color red}${blink Tor Off}
#$endif
$endif
${color5}${stippled_hr}${font}${voffset -0}
#${if_existing /home/alves/.kbase/dns/autodnscrypt}
${if_running dnscrypt-proxy}#${image /home/alves/.kbase/.conky/images/dnson.png -p 105,70 -s 16x16}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}DnsCrypt: ${color3}${alignr}Age: ${color1}${exec ps -eo pid,command,etime|grep 'dnscrypt-proxy'|cut -d c -f 3|xargs}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Age:${color1}${alignr}${exec ps -eo pid,command,etime|grep 'dnscrypt-proxy'|cut -d y -f 4|awk 'NR==2'|tr -d " \t\n\r"}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Age:${color1}${alignr}${exec ps -eo pid,command,etime|grep 'dnscrypt-proxy'|cut -d y -f 3|awk 'NR==2; END{print}'|xargs|tr -d " \t\n\r"}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Age:${color1}${alignr}${exec ps -eo pid,command,etime|grep 'dnscrypt-proxy'|grep 'oxy -c'|cut -d r -f 4|awk  '{print $3}'|xargs}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Provider:${color1}${alignr}${exec cat /etc/resolv.conf |grep Dnsused|cut -d : -f 2|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}${color1}${exec cat /etc/resolv.conf |grep nameserver|cut -d r -f 3| awk 'NR==1'|xargs}${alignr}${color3}${color1}${alignr}${exec cat /etc/resolv.conf |grep nameserver|cut -d r -f 3| awk 'NR==2'|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Forced DNS:${font Liberation Sans Narrow:size=10:bold}${color1}${alignr}${exec cat /home/alves/.kbase/forcetempdns|cut -d : -f 2|xargs }
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Tor DNS:${font Liberation Sans Narrow:size=10:bold} ${alignr}${color red}${exec cat /home/alves/.kbase/tordnsstatus|cut -d : -f 2|xargs }
$else
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}DNS${color1}${alignr}${exec cat /etc/resolv.conf |grep Dnsused|cut -d : -f 2|tr -d " \t\n\r"}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Age:${color1}${alignr}${exec ps -eo pid,command,etime|grep 'dnscrypt-proxy'|cut -d y -f 4|xargs|tr -d " \t\n\r"}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}${exec cat /etc/resolv.conf |grep nameserver|cut -d r -f 3| awk 'NR==1'|xargs}${color1}${alignr}${exec cat /etc/resolv.conf |grep nameserver|cut -d r -f 3| awk 'NR==2'|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Forced DNS:${font Liberation Sans Narrow:size=10:bold}${color1}${alignr}${exec cat /home/alves/.kbase/forcetempdns|cut -d : -f 2|xargs }
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}DnsCrypt ${font Liberation Sans Narrow:size=10:bold} ${alignr}${color1}No
#${image /home/alves/.kbase/.conky/images/dnsoff.png -p 40,340 -s 16x16}
$endif
${color5}${stippled_hr}${font}${voffset -0}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Status do lmpanel:${alignr}${color1}${font Liberation Sans Narrow:size=10:bold}${exec cat /home/alves/.kbase/BandSatus |xargs} 
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Versão: ${color1}${exec cat /home/alves/.kbase/Globalconfig|grep "Kodachi_version"|cut -d = -f 2|cut -d ';' -f 1|xargs}${alignr}${color3}Última: ${color1}${exec cat /home/alves/.kbase/version|xargs|tr -d " \t\n\r"}${color red}${exec cat /home/alves/.kbase/newversionalert|xargs|tr -d " \t\n\r"}
#${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}IP updates in:${color1}${alignr}${exec cat /home/alves/.kbase/.countfile|wc -l|cut -d . -f 1}${color2}/25
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Modo de boot do SO: ${color1}${exec cat /home/alves/.kbase/boottype}${alignr}${color3}SO live: ${color1}${exec cat /home/alves/.kbase/persistent}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}SO criptografado: ${color1}${exec cat /home/alves/.kbase/hddencrypted|xargs}${alignr}${color3}SO nuked: ${color1}${exec cat /home/alves/.kbase/nuked|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}VPN Firewall: ${color1}${exec cat /home/alves/.kbase/vpnufwstatus|xargs}${alignr}${color3}IPv6: ${alignr}${color1}${exec cat /home/alves/.kbase/ipv6status|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Autologin do SO: ${color1}${exec cat /home/alves/.kbase/autologinstatus|xargs}${alignr}${color3}CUPS da impressora: ${color1}${exec cat /home/alves/.kbase/cupsstatus|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Swap criptografado: ${color1}${exec cat /home/alves/.kbase/swapcrypt|xargs}${alignr}${color3}${alignr}${color3}Total de swaps: ${color1}${exec cat /home/alves/.kbase/totalswaps|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Ajuste automático da fonte da tela:${alignr}${color1}${exec cat /home/alves/.kbase/forcefonts}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Status de atualização:${alignr}${color1}${font Liberation Sans Narrow:size=10:bold}${exec cat /home/alves/.kbase/healthsactionstatus |xargs}
${color5}${stippled_hr}${font}${voffset -0}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Pontuação de segurança: ${alignr}${color1}${exec cat /home/alves/.kbase/securityscore|xargs}/100
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Seu modelo:${alignr}${color1}${exec cat /home/alves/.kbase/securitymodel|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Melhor modelo:${alignr}${color1}ISP->VPN->Torify->TorDNS
