# Duplicate of .conkyrc1 for the second monitor.
gap_x 1318
gap_y 23
update_interval 5
minimum_size 220 0
maximum_width 360
use_xft yes
xftfont caviar dreams:size=10
xftalpha 0.8
uppercase no
background yes
cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius
no_buffers yes
text_buffer_size 256
default_color FFFFFF
color1 8BB158
color2 7D7B7D
color3 7D7B7D
color4 FFFFF
color5 353535
own_window yes
own_window_type desktop
own_window_argb_visual yes
own_window_argb_value 90
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
total_run_times 0
draw_shades no
draw_outline no
draw_borders no
draw_graph_borders no
stippled_borders 0
border_margin 5
border_width 3
default_color 05FBE8
own_window_colour black
xinerama_head 1
alignment top_left
override_utf8_locale yes
use_spacer none
TEXT
${voffset 1}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}CPU ${font Liberation Sans Narrow:size=10:bold}${color3}${alignr}${cpu}%
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}1. ${top name 1}${alignr}${top cpu 1}%
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}2. ${top name 2}${alignr}${top cpu 2}%
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}3. ${top name 3}${alignr}${top cpu 3}%
${goto 5}${loadgraph 10,220 666666 666666}
${color5}${stippled_hr}${font}${voffset -0}
${voffset 10}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}MEM ${color1}${exec free | awk '/Mem/{printf("%.2f%"), $3/$2*100} /buffers\/cache/{printf(", buffers: %.2f%"), $3/$2*100}' }${color1}${alignr}${exec cat /home/alves/.kbase/Memused}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}1. ${top_mem name 1}${alignr}${top_mem mem 1}%
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}2. ${top_mem name 2}${alignr}${top_mem mem 2}%
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}3. ${top_mem name 3}${alignr}${top_mem mem 3}%
${color5}${stippled_hr}${font}${voffset -0}
${voffset 10}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}DISKS
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}1. used:${alignr}${fs_used /home}${color2} /home
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color1}2. used:${alignr}${fs_used /}${color2} /
${goto 5}${diskiograph 10,220 666666 666666}
