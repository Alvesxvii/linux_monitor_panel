#!/usr/bin/env bash
set -euo pipefail

local_conky="$HOME/.local/bin/usr/bin/conky"
if [[ -x "$local_conky" ]]; then
  LD_LIBRARY_PATH="$HOME/.local/lib/lmpanel/lib/x86_64-linux-gnu:$HOME/.local/lib/lmpanel/usr/lib/x86_64-linux-gnu:$HOME/.local/lib/lmpanel/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
    exec "$local_conky" "$@"
fi

exec conky "$@"
