#!/usr/bin/env bash
set -euo pipefail

panel_script="$HOME/.lmpanel/lmpanel.sh"
edit_target_file="$HOME/.lmpanel/edit-target"

if [[ ! -x "$panel_script" ]]; then
  echo "lmpanel: script principal ausente em $panel_script" >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Uso:
  lmpanel edit               # entra no modo de edição manual e arrasta os painéis
  lmpanel save               # salva as posições atuais dos painéis manuais
  lmpanel auto               # volta para o layout automático baseado no monitor
  lmpanel set-auto           # salva as posições atuais como base automática
  lmpanel profile 1|2|3      # ativa o perfil salvo 1, 2 ou 3
  lmpanel set-profile 1|2|3  # entra no modo de edição para o perfil 1, 2 ou 3
  lmpanel save-profile       # salva o perfil que está sendo editado no momento
  lmpanel wallpaper list     # lista os wallpapers disponíveis em ~/.local/share/backgrounds/lmpanel
  lmpanel wallpaper remember # lembra o wallpaper atual do sistema como base de restauração
  lmpanel wallpaper system   # restaura o wallpaper definido pelo sistema
  lmpanel wallpaper next     # vai para o próximo wallpaper do diretório do lmpanel
  lmpanel wallpaper prev     # volta para o wallpaper anterior do diretório do lmpanel
  lmpanel wallpaper <arquivo> # aplica um wallpaper pelo nome do arquivo no diretório do lmpanel
  lmpanel                    # mostra esta ajuda
EOF
}

validate_profile() {
  case "${1:-}" in
    1|2|3) return 0 ;;
    *)
      echo "lmpanel: o número do perfil deve ser 1, 2 ou 3" >&2
      return 1
      ;;
  esac
}

case "${1:-}" in
  edit|save|auto|set-auto|profile|set-profile|save-profile|wallpaper)
    case "$1" in
      edit)
        printf 'manual\n' >"$edit_target_file"
        nohup "$panel_script" --edit >/dev/null 2>&1 &
        disown 2>/dev/null || true
        ;;
      save) exec "$panel_script" --save-layout ;;
      auto) exec "$panel_script" --auto-layout ;;
      set-auto) exec "$panel_script" --set-auto-layout ;;
      profile)
        validate_profile "${2:-}" || exit 1
        exec "$panel_script" --profile-layout "$2"
        ;;
      set-profile)
        validate_profile "${2:-}" || exit 1
        printf 'profile-%s\n' "$2" >"$edit_target_file"
        nohup "$panel_script" --edit >/dev/null 2>&1 &
        disown 2>/dev/null || true
        ;;
      save-profile) exec "$panel_script" --save-profile-layout ;;
      wallpaper)
        case "${2:-}" in
          list)
            exec "$panel_script" --list-wallpapers
            ;;
          remember)
            exec "$panel_script" --remember-wallpaper
            ;;
          system)
            exec "$panel_script" --system-wallpaper
            ;;
          next)
            exec "$panel_script" --next-wallpaper
            ;;
          prev)
            exec "$panel_script" --prev-wallpaper
            ;;
          "")
            usage
            ;;
          *)
            exec "$panel_script" --set-wallpaper "$2"
            ;;
        esac
        ;;
    esac
    ;;
  help|-h|--help|"")
    usage
    ;;
  *)
    echo "lmpanel: comando desconhecido: $1" >&2
    echo "Tente: lmpanel --help" >&2
    exit 1
    ;;
esac
