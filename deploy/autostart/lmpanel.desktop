[Desktop Entry]
Type=Application
Name=Linux Monitor Panel
Comment=Desktop information overlay
Exec=/bin/sh -lc 'sleep 3; systemctl --user import-environment DISPLAY WAYLAND_DISPLAY XAUTHORITY DBUS_SESSION_BUS_ADDRESS; systemctl --user restart lmpanel.service'
Terminal=false
StartupNotify=false
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=5
OnlyShowIn=GNOME;XFCE;MATE;Cinnamon;Unity;Budgie;
