# Crypto quotes card for the first monitor.
gap_x 1058
gap_y 580
update_interval 10
minimum_size 220 0
maximum_width 360
use_xft yes
xftfont caviar dreams:size=10
xftalpha 0.8
uppercase no
background yes
cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius
no_buffers yes
text_buffer_size 256
default_color FFFFFF
color1 8BB158
color2 7D7B7D
color3 7D7B7D
color4 FFFFF
color5 353535
own_window yes
own_window_type desktop
own_window_argb_visual yes
own_window_argb_value 90
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
total_run_times 0
draw_shades no
draw_outline no
draw_borders no
stippled_borders 0
border_margin 5
border_width 3
default_color 05FBE8
own_window_colour black
xinerama_head 0
alignment top_left
override_utf8_locale yes
use_spacer none
TEXT
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}CRIPTOMOEDAS ${color5}${stippled_hr}${font}${voffset -0}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}BTC/USDT: ${color1}${exec cat /home/alves/.kbase/btcprice|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}USDT/BRL: ${color1}${exec cat /home/alves/.kbase/usdtprice|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Domínio usado: ${color1}${exec cat /home/alves/.kbase/randomDomain|xargs}
