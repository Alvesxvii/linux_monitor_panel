# Duplicate of .conkyrc2 for the second monitor.
gap_x 1058
gap_y 343
update_interval 10
minimum_size 220 0
maximum_width 360
use_xft yes
xftfont caviar dreams:size=10
xftalpha 0.8
uppercase no
background yes
cpu_avg_samples 2
net_avg_samples 2
temperature_unit celsius
no_buffers yes
text_buffer_size 256
default_color FFFFFF
color1 8BB158
color2 7D7B7D
color3 7D7B7D
color4 FFFFF
color5 353535
own_window yes
own_window_type desktop
own_window_argb_visual yes
own_window_argb_value 90
own_window_hints undecorated,below,sticky,skip_taskbar,skip_pager
double_buffer yes
total_run_times 0
draw_shades no
draw_outline no
draw_borders no
stippled_borders 0
border_margin 5
border_width 3
default_color 05FBE8
own_window_colour black
xinerama_head 1
alignment top_left
override_utf8_locale yes
use_spacer none
TEXT
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}PRIVACIDADE E SEGURANÇA ${color5}${stippled_hr}${font}${voffset -0}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Internet:${alignr}${color1}${exec cat /home/alves/.kbase/netCurrentStatus|xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color2}Interface de rede:${alignr}${color1}${exec cat /home/alves/.kbase/intfused |xargs}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Gateway: ${alignr}${color1}${if_gw}${gw_ip}${else}-${endif}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}MAC:${color1}${alignr}${exec cat /sys/class/net/$(find /sys/class/net ! -type d | xargs --max-args=1 realpath  | awk -F\/ '/pci/{print $NF}'|head -n1)/address}
${goto 5}${font Liberation Sans Narrow:size=10:bold}${color3}Origem IP:${color1}${alignr}${exec cat /home/alves/.kbase/iptypeletter |xargs}
